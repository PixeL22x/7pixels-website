# Authentication Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-here

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# Google OAuth (Optional - for Google Sign In)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email Configuration (Resend)
AUTH_RESEND_KEY=re_xxxxxxxxxx
EMAIL_FROM=noreply@7pixels.es

# INSTRUCCIONES SÚPER FÁCILES:
# 
# 1. Copia este archivo como .env.local
# 2. Configura las variables según tu setup:
#
# MONGODB_URI: Tu conexión de MongoDB Atlas
# NEXTAUTH_SECRET: Genera con: openssl rand -base64 32
# GOOGLE_CLIENT_ID/SECRET: Para login con Google (opcional)
# AUTH_RESEND_KEY: Tu API key de Resend
# EMAIL_FROM: Email desde el que se envían los mensajes
#
# VENTAJAS DE RESEND:
# ✅ Gratis hasta 3,000 emails/mes
# ✅ Sin configuración SMTP complicada
# ✅ Perfecto para Vercel
# ✅ Analytics incluidos
# ✅ Excelente deliverability
#
# IMPORTANTE: 
# 1. Copia este archivo como .env.local
# 2. Configura todas las variables necesarias
# 3. En Vercel: Agrega todas las variables en Environment Variables
